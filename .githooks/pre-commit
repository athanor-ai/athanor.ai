#!/bin/bash
# Pre-commit hook: validate data.js before pushing
set -e

if [ -f data.js ]; then
    echo "Validating data.js..."
    python3 test_data.py
    if [ $? -ne 0 ]; then
        echo ""
        echo "BLOCKED: data.js validation failed. Fix before committing."
        exit 1
    fi
fi

# Check index.html references data.js
if [ -f index.html ]; then
    if ! grep -q 'src="data.js"' index.html; then
        echo "BLOCKED: index.html must reference data.js"
        exit 1
    fi
fi

echo "Pre-commit checks passed."
